# Test runner for the gem on Linux. macOS silently no-ops setsockopt(TCP_USER_TIMEOUT)
# via Errno::ENOPROTOOPT; the tests that observe kernel-level wedge resolution skip
# unless RUBY_PLATFORM includes "linux", so we run them via a Linux container.
FROM ruby:3.3-slim

RUN apt-get update -qq \
  && apt-get install -y --no-install-recommends \
       build-essential \
       git \
       libyaml-dev \
       pkg-config \
  && rm -rf /var/lib/apt/lists/*

ENV BUNDLE_PATH=/bundle BUNDLE_DISABLE_SHARED_GEMS=true

WORKDIR /app
RUN git config --global --add safe.directory /app

CMD ["bash"]
